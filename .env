# Variáveis de Ambiente — API (.env)

# Porta e ambiente
NODE_ENV=development
PORT=8000
TZ=America/Sao_Paulo

# JWT (somente para desenvolvimento local)
JWT_SECRET=dev-secret-change-me-local-2026
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-local-2026
SESSION_TIMEOUT=8h

# Frontend local
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Banco de Dados — Somente PostgreSQL
## Opção 1: Railway Postgres (URL completa)
# DATABASE_URL=postgresql://usuario:senha@host:porta/database?sslmode=require

## Opção 2: PostgreSQL local
DATABASE_URL=postgresql://prescrimed:prescrimed-local-2026@localhost:5433/prescrimed?sslmode=disable
