# ===================================
# Prescrimed - Producao HostGator
# ===================================
# Use este arquivo como base para o .env de producao.
# Requer plano com Node.js e PostgreSQL acessivel.

# --- Ambiente ---
NODE_ENV=production
TZ=America/Sao_Paulo

# --- Servidor ---
# Em muitos ambientes Node do HostGator o proprio painel injeta PORT.
# Se o painel exigir valor fixo, ajuste aqui.
PORT=3000

# --- Banco de Dados (PostgreSQL / Supabase) ---
# Opcao preferencial: URL unica.
DATABASE_URL=postgresql://USUARIO:SENHA@HOST:5432/NOME_DO_BANCO?sslmode=require

# Se estiver usando Supabase, tambem pode usar um destes aliases:
# SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:SENHA@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# SUPABASE_POOLER_URL=postgresql://postgres.PROJECT_REF:SENHA@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Opcao alternativa: variaveis separadas.
# PGHOST=HOST
# PGPORT=5432
# PGDATABASE=NOME_DO_BANCO
# PGUSER=USUARIO
# PGPASSWORD=SENHA

# --- JWT / Sessao ---
JWT_SECRET=troque-por-um-segredo-longo-com-64-caracteres-ou-mais
JWT_REFRESH_SECRET=troque-por-outro-segredo-longo-com-64-caracteres-ou-mais
SESSION_TIMEOUT=8h

# --- Frontend / CORS / URL publica ---
FRONTEND_URL=https://prescrimed.com.br
URL_FRONTEND=https://prescrimed.com.br
CORS_ORIGIN=https://prescrimed.com.br
ALLOWED_ORIGINS=https://prescrimed.com.br,https://www.prescrimed.com.br
PUBLIC_BASE_URL=https://prescrimed.com.br

# --- Frontend HostGator (usado no build estatico do Template) ---
# O script npm run hostgator:prepare converte estas chaves em client/.env.hostgator.local
VITE_API_URL=/api
VITE_BACKEND_ROOT=https://prescrimed.com.br
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=cole-aqui-a-anon-key-publica

# --- Bootstrap inicial HostGator ---
# Rode uma vez com: npm run seed:hostgator
HOSTGATOR_EMPRESA_NOME=Prescrimed
HOSTGATOR_EMPRESA_TIPO=casa-repouso
HOSTGATOR_EMPRESA_CNPJ=00000000000191
HOSTGATOR_EMPRESA_EMAIL=contato@prescrimed.com.br
HOSTGATOR_ADMIN_NOME=Administrador Prescrimed
HOSTGATOR_ADMIN_EMAIL=prescrimed@prescrimed.com.br
HOSTGATOR_ADMIN_PASSWORD=defina-uma-senha-forte-aqui

# --- Opcional: criacao/atualizacao de superadmin ---
# Rode sob demanda com: npm run create:superadmin
# SUPERADMIN_EMAIL=prescrimed@prescrimed.com.br
# SUPERADMIN_PASSWORD=defina-outra-senha-forte-aqui
# SUPERADMIN_NOME=Super Admin Prescrimed

# --- Opcional: SMTP para notificacoes por email ---
# SMTP_HOST=smtp.seudominio.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=usuario@seudominio.com
# SMTP_PASS=senha-smtp
# SMTP_FROM=Prescrimed <no-reply@prescrimed.com.br>

# --- Opcional: Pagamentos ---
# PAYMENT_PROVIDER=mercado-pago
# PAYMENT_PROVIDER_BASE_URL=https://api.seu-provedor.com
# PAYMENT_PROVIDER_TOKEN=seu-token
# PAYMENT_PROVIDER_CHECKOUT_PATH=/checkout
# PAYMENT_PROVIDER_TIMEOUT_MS=15000
# PAYMENT_WEBHOOK_SECRET=segredo-do-webhook
# PAYMENT_WEBHOOK_STRICT=true

# --- Opcional: Fiscal ---
# FISCAL_PROVIDER=nuvem-fiscal
# FISCAL_PROVIDER_BASE_URL=https://api.seu-provedor-fiscal.com
# FISCAL_PROVIDER_TOKEN=seu-token-fiscal
# FISCAL_PROVIDER_INVOICE_PATH=/invoices
# FISCAL_PROVIDER_TIMEOUT_MS=15000
# FISCAL_ENVIRONMENT=producao
# NFSE_CITY_CODE=3550308
# AUTO_EMIT_FISCAL_ON_PAYMENT_APPROVED=true

# --- Opcional: Backups automaticos ---
# BACKUP_AUTO_ENABLED=false
# BACKUP_AUTO_INTERVAL_HOURS=24
# BACKUP_AUTO_SEND_EMAIL=true
# BACKUP_AUTO_INCLUDE_INACTIVE=false
# BACKUP_AUTO_INITIAL_DELAY_MS=60000
# BACKUP_RETENTION_COUNT=30
# BACKUP_RETENTION_DAYS=30
# BACKUP_DIR=./data/backups